        "${HAY_SAY_HOME:-/home/luna/hay_say}/.venvs/controllable_talknet/bin/python",
        "${HAY_SAY_HOME:-/home/luna/hay_say}/controllable_talknet_server/main.py",
        "--cache_implementation",
        "file"
      ],
      "cwd": "${HAY_SAY_HOME:-/home/luna/hay_say}/controllable_talknet",
      "env": {"PYTHONUNBUFFERED": "1"},
      "device": "auto",
      "runtime_endpoint": "/runtime",
