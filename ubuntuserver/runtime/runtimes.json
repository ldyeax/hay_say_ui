{
  "version": 1,
  "manager": {
    "state_dir": "${HAY_SAY_RUNTIME_STATE_DIR:-/home/luna/.local/state/hay-say/runtimes}",
    "log_dir": "${HAY_SAY_RUNTIME_LOG_DIR:-/home/luna/.local/state/hay-say/logs}",
    "api_host": "127.0.0.1",
    "api_port": 6588,
    "request_timeout_seconds": 5.0,
    "start_grace_seconds": 30.0,
    "stop_timeout_seconds": 15.0,
    "collect_gpu_memory": true
  },
  "runtimes": [
    {
      "id": "controllable_talknet",
      "label": "Controllable TalkNet",
      "port": 6574,
